      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction extractJsonText(value) {\n  if (value == null) return '{}';\n\n  if (typeof value === 'object') {\n    if (typeof value.output === 'string') return value.output;\n    return JSON.stringify(value);\n  }\n\n  let text = String(value).trim();\n\n  // Strip markdown fences if model adds them.\n  text = text.replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```$/i, '').trim();\n\n  // If the agent returned an array wrapper, parse wrapper first.\n  if (text.startsWith('[')) {\n    const parsed = JSON.parse(text);\n    const first = parsed[0] || {};\n    if (typeof first.output === 'string') return first.output;\n    return JSON.stringify(first);\n  }\n\n  return text;\n}\n\nfunction parseAgentOutput(raw) {\n  const text = extractJsonText(raw);\n\n  try {\n    return JSON.parse(text);\n  } catch {\n    return {\n      status: 'HARD_FAIL',\n      message: 'I had trouble formatting that response. Please try again.',\n      state_delta: {\n        matcher_state: {\n          conversation_context: { awaiting: null }\n        }\n      },\n      options: []\n    };\n  }\n}\n\nreturn items.map(item => ({\n  json: parseAgentOutput(item.json.output ?? item.json)\n}));"
      },
